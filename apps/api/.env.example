# Kandha API environment variables — copy to .env and fill in values

# --- GMI Cloud / Kimi K2 ---
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi.ai/v1
GMI_MODEL=kimi-k2-5

# --- Dify ---
DIFY_API_KEY=
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_WORKFLOW_ID_ANALYZE=
DIFY_WORKFLOW_ID_MIGRATE=
DIFY_WORKFLOW_ID_INFRA=

# --- HydraDB ---
HYDRA_API_KEY=
HYDRA_BASE_URL=
HYDRA_TENANT_ID=kandha

# --- Photon ---
PHOTON_API_KEY=
PHOTON_ENDPOINT=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://kandha:kandha@localhost:5432/kandha

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=kandha
MINIO_SECRET_KEY=kandha_secret
MINIO_BUCKET=kandha-uploads
MINIO_SECURE=false

# --- App ---
SECRET_KEY=change_me_in_production
LOG_LEVEL=INFO
